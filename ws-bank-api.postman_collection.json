{
  "info": {
    "name": "WS Bank API",
    "_postman_id": "6e68d1c7-56c7-4c6f-b686-2b0a542bcb20",
    "description": "Collection para testar o fluxo da API bancaria local.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Reset state",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/reset",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reset"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('body is OK', function () {",
              "  pm.expect(pm.response.text()).to.eql('OK');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Create account with initial balance",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"type\":\"deposit\",\"destination\":\"100\",\"amount\":10}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/event",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "event"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('destination account has balance 10', function () {",
              "  pm.expect(pm.response.json()).to.eql({",
              "    destination: { id: '100', balance: 10 }",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Deposit into existing account",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
