      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('destination account has balance 20', function () {",
              "  pm.expect(pm.response.json()).to.eql({",
              "    destination: { id: '100', balance: 20 }",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Get balance for existing account after deposits",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/balance?account_id=100",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "balance"
          ],
          "query": [
            {
              "key": "account_id",
              "value": "100"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('body is 20', function () {",
              "  pm.expect(pm.response.text()).to.eql('20');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Withdraw from non-existing account",
